# ============================================
# VERCEL PRO - Sistema de Cotizaciones Enterprise
# ============================================

# 1. GOOGLE SHEETS (Almacenamiento de cotizaciones)
GOOGLE_SHEETS_API_KEY=tu_api_key_google_sheets
GOOGLE_SHEETS_ID=tu_sheet_id_aqui

# 2. WHATSAPP (Twilio)
TWILIO_ACCOUNT_SID=tu_account_sid_twilio
TWILIO_AUTH_TOKEN=tu_auth_token_twilio
TWILIO_WHATSAPP_NUMBER=+14155552671  # Número de Twilio para WhatsApp

# 3. SLACK (Notificaciones al equipo)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# 4. NOTION (Base de datos de cotizaciones)
NOTION_API_KEY=tu_notion_api_key
NOTION_DATABASE_ID=tu_notion_database_id

# 5. MONDAY.COM (Tablero de proyectos)
MONDAY_API_TOKEN=tu_monday_api_token
MONDAY_BOARD_ID=tu_board_id_aqui

# 6. CLOUDFLARE (CDN + Workers)
CLOUDFLARE_API_TOKEN=tu_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=tu_cloudflare_account_id
CLOUDFLARE_ZONE_ID=tu_zone_id

# 7. CLAUDE AI (MCP - Model Context Protocol)
CLAUDE_API_KEY=tu_claude_api_key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# 8. Base de datos (si usas BD tradicional)
DB_HOST=localhost
DB_USER=merlinsmkt_user
DB_PASS=tu_password_seguro
DB_NAME=merlinsmkt_db

# 9. Configuración de email
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=tu_email@merlinsmkt.com
SMTP_PASS=tu_app_password

# 10. Seguridad y producción
NODE_ENV=production
VERCEL_ENV=production
JWT_SECRET=tu_jwt_secret_super_seguro_aqui
